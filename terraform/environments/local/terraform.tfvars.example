# Copy to terraform.tfvars (gitignored) and adjust for your machine.
# Or export equivalents as TF_VAR_* environment variables.

cluster_name      = "orion-local"
worker_nodes      = 2
kubeconfig_path   = "~/.kube/orion-local-config"
ingress_host_port = 8080
node_image        = "kindest/node:v1.31.0"
